# Copy to .env.local and fill in from your Supabase project:
# Dashboard -> Project Settings -> API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
# Web-push VAPID public key (public-safe; the private half lives only in
# Supabase Edge Function secrets). Generate: pnpm dlx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
